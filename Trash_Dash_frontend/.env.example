# Copia questo file in .env solo se vuoi configurare manualmente gli URL.
# Lascia le righe commentate se usi lo script start-light-windows.ps1.
#
# PC/web:
# EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api
# EXPO_PUBLIC_WS_URL=ws://localhost:4000/ws
#
# Expo Go su telefono reale: sostituisci TUO_IP_LOCALE con l'IP LAN del PC.
# Esempio: http://192.168.1.25:4000/api
# EXPO_PUBLIC_API_BASE_URL=http://TUO_IP_LOCALE:4000/api
# EXPO_PUBLIC_WS_URL=ws://TUO_IP_LOCALE:4000/ws
